<!DOCTYPE html>
<html
  lang={E2eWeb.Locale.current()}
  dir={E2eWeb.Locale.dir(E2eWeb.Locale.current())}
  data-theme={assigns[:theme]}
  data-mode={assigns[:mode] || "light"}
  data-authoring={assigns[:authoring] || "attr"}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.head seo={assigns[:seo]} page_title={assigns[:page_title]} />
    <meta name="theme-color" content="#F5F7FA" />
    <link rel="icon" href={~p"/images/favicon.ico"} />
    <link rel="apple-touch-icon" sizes="180x180" href={~p"/images/apple-touch-icon-180x180.png"} />
    <link rel="icon" type="image/png" sizes="192x192" href={~p"/images/pwa-192x192.png"} />
    <link rel="icon" type="image/png" sizes="512x512" href={~p"/images/pwa-512x512.png"} />
    <link rel="mask-icon" href={~p"/images/maskable-icon-512x512.png"} color="#F5F7FA" />
    <link rel="icon" type="image/png" sizes="64x64" href={~p"/images/pwa-64x64.png"} />
    <link
      phx-track-static
      rel="stylesheet"
      href={E2eWeb.Endpoint.static_path("/assets/css/site.css")}
    />

    <script defer phx-track-static type="module" src={~p"/assets/js/app.js"}>
    </script>

    {Phoenix.HTML.raw("<script>\n" <> E2eWeb.PreviewSettings.full_script() <> "\n</script>")}
  </head>
  <body class="antialiased min-h-dvh bg-root text-ui-ink overflow-x-hidden">
    <.navigate to="#main-content" class="link link--skip">{~t"Skip to content"}</.navigate>
    {@inner_content}
  </body>
</html>
