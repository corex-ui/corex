<!DOCTYPE html>
<html lang="en" data-theme="neo" data-mode="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{~t"Page Not Found"}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="crossorigin" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300..900;1,300..900&display=optional"
    />
    <link phx-track-static rel="stylesheet" href="/assets/css/site.css" />
  </head>
  <body class="antialiased min-h-dvh bg-root text-ui-ink overflow-x-hidden">
    <.stack
      tag="main"
      id="main-content"
      width="full"
      align="center"
      justify="center"
      gap="lg"
      padding="lg"
      class="min-h-dvh shell-main--marketing"
    >
      <.container size="lg" class="text-center">
        <.stack align="center" gap="lg">
          <p class="m-0 font-display text-display-sm text-ui-ink-accent">404</p>
          <h1 class="m-0">{~t"Page Not Found"}</h1>
          <p class="m-0 text-ui-ink-muted">
            {~t"Sorry, the page you are looking for does not exist."}
          </p>
          <.navigate to={~p"/"} as="button" semantic="accent" size="lg">
            {~t"Go home"}
          </.navigate>
        </.stack>
      </.container>
    </.stack>
  </body>
</html>
