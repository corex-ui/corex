<Layouts.app flash={@flash} mode={@mode} theme={@theme} path={@path}>
  <.demo_page
    path={@path}
    id="file-upload-styling-page"
    title={~t"File Upload · Style"}
    subtitle={
      ~t"Semantic colors, density, and corner radius via component attrs on the file upload root."
    }
  >
    <.demo_section
      id="file-upload-styling-semantic"
      title={~t"Semantic"}
      values={E2eWeb.Demos.FileUploadDemo.styling_axis_values(:semantic)}
      code={E2eWeb.Demos.FileUploadDemo.styling_semantic_code()}
    >
      <:preview>
        <E2eWeb.Demos.FileUploadDemo.styling_semantic_example />
      </:preview>
    </.demo_section>

    <.demo_section
      id="file-upload-styling-size"
      title={~t"Size"}
      values={E2eWeb.Demos.FileUploadDemo.styling_axis_values(:size)}
      code={E2eWeb.Demos.FileUploadDemo.styling_size_code()}
    >
      <:preview>
        <E2eWeb.Demos.FileUploadDemo.styling_size_example />
      </:preview>
    </.demo_section>

    <.demo_section
      id="file-upload-styling-radius"
      title={~t"Radius"}
      values={E2eWeb.Demos.FileUploadDemo.styling_axis_values(:radius)}
      code={E2eWeb.Demos.FileUploadDemo.styling_radius_code()}
    >
      <:preview>
        <E2eWeb.Demos.FileUploadDemo.styling_radius_example />
      </:preview>
    </.demo_section>
  </.demo_page>
</Layouts.app>
