<Layouts.app flash={@flash} mode={@mode} theme={@theme} path={@path}>
  <.demo_page
    path={@path}
    id="listbox-styling-page"
    title={~t"Listbox · Style"}
    subtitle={
      ~t"Selected-item colors, density, and width via modifier classes and Tailwind max-w-* on the listbox root (vertical by default; horizontal uses a wider default max width)."
    }
  >
    <.demo_section
      id="listbox-styling-semantic"
      title={~t"Semantic"}
      values={E2eWeb.Demos.ListboxDemo.styling_axis_values(:semantic)}
      code={E2eWeb.Demos.ListboxDemo.styling_semantic_code()}
    >
      <:preview>
        <E2eWeb.Demos.ListboxDemo.styling_semantic_example />
      </:preview>
    </.demo_section>

    <.demo_section
      id="listbox-styling-size"
      title={~t"Size"}
      values={E2eWeb.Demos.ListboxDemo.styling_axis_values(:size)}
      code={E2eWeb.Demos.ListboxDemo.styling_size_code()}
    >
      <:preview>
        <E2eWeb.Demos.ListboxDemo.styling_size_example />
      </:preview>
    </.demo_section>

    <.demo_section
      id="listbox-styling-max-width"
      title={~t"Max width"}
      values={E2eWeb.Demos.ListboxDemo.styling_axis_values(:max_width)}
      code={E2eWeb.Demos.ListboxDemo.styling_max_width_code()}
    >
      <:preview>
        <E2eWeb.Demos.ListboxDemo.styling_max_width_example />
      </:preview>
    </.demo_section>
  </.demo_page>
</Layouts.app>
