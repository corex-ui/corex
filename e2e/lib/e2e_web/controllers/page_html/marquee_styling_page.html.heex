<Layouts.app flash={@flash} mode={@mode} theme={@theme} path={@path}>
  <.demo_page
    path={@path}
    id="marquee-styling-page"
    title={~t"Marquee · Style"}
    subtitle={~t"Item scale via size modifiers; host width via Tailwind max-w-* utilities."}
  >
    <.demo_section
      id="marquee-styling-size"
      title={~t"Size"}
      code={E2eWeb.Demos.MarqueeDemo.styling_size_code()}
    >
      <:description>
        <.demo_modifier_axis name="marquee" axis={:size} />
      </:description>
      <:preview>
        <E2eWeb.Demos.MarqueeDemo.styling_size_example />
      </:preview>
    </.demo_section>

    <.demo_section
      id="marquee-styling-max-width"
      title={~t"Max width"}
      code={E2eWeb.Demos.MarqueeDemo.styling_max_width_code()}
    >
      <:description>
        <.demo_modifier_axis name="marquee" axis={:max_width} />
      </:description>
      <:preview>
        <E2eWeb.Demos.MarqueeDemo.styling_max_width_example />
      </:preview>
    </.demo_section>
  </.demo_page>
</Layouts.app>
