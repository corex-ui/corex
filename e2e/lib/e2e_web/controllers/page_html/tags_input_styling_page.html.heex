<Layouts.app flash={@flash} mode={@mode} theme={@theme} path={@path}>
  <.demo_page
    path={@path}
    id="tags-input-styling-page"
    title={~t"Tags input · Style"}
    subtitle={
      ~t"Semantic preview ink and delete-trigger themes, density steps, type scale, radii, and host max-width utilities—same modifier pattern as accordion."
    }
  >
    <.demo_section
      id="tags-input-styling-semantic"
      title={~t"Semantic"}
      values={E2eWeb.Demos.TagsInputDemo.styling_axis_values(:semantic)}
      code={E2eWeb.Demos.TagsInputDemo.styling_semantic_heex()}
    >
      <:preview>
        <E2eWeb.Demos.TagsInputDemo.styling_semantic_example />
      </:preview>
    </.demo_section>

    <.demo_section
      id="tags-input-styling-trigger"
      title={~t"Delete trigger"}
      code={E2eWeb.Demos.TagsInputDemo.styling_trigger_heex()}
    >
      <:preview>
        <E2eWeb.Demos.TagsInputDemo.styling_trigger_example />
      </:preview>
    </.demo_section>

    <.demo_section
      id="tags-input-styling-size"
      title={~t"Size"}
      values={E2eWeb.Demos.TagsInputDemo.styling_axis_values(:size)}
      code={E2eWeb.Demos.TagsInputDemo.styling_size_heex()}
    >
      <:preview>
        <E2eWeb.Demos.TagsInputDemo.styling_size_example />
      </:preview>
    </.demo_section>

    <.demo_section
      id="tags-input-styling-text"
      title={~t"Text"}
      values={E2eWeb.Demos.TagsInputDemo.styling_axis_values(:text)}
      code={E2eWeb.Demos.TagsInputDemo.styling_text_heex()}
    >
      <:preview>
        <E2eWeb.Demos.TagsInputDemo.styling_text_example />
      </:preview>
    </.demo_section>

    <.demo_section
      id="tags-input-styling-radius"
      title={~t"Radius"}
      values={E2eWeb.Demos.TagsInputDemo.styling_axis_values(:radius)}
      code={E2eWeb.Demos.TagsInputDemo.styling_radius_heex()}
    >
      <:preview>
        <E2eWeb.Demos.TagsInputDemo.styling_radius_example />
      </:preview>
    </.demo_section>

    <.demo_section
      id="tags-input-styling-max-width"
      title={~t"Max width"}
      values={E2eWeb.Demos.TagsInputDemo.styling_axis_values(:max_width)}
      code={E2eWeb.Demos.TagsInputDemo.styling_max_width_heex()}
    >
      <:preview>
        <E2eWeb.Demos.TagsInputDemo.styling_max_width_example />
      </:preview>
    </.demo_section>
  </.demo_page>
</Layouts.app>
