<Layouts.app
  flash={@flash}
  mode={@mode}
  theme={@theme}
  path={@path}
>
  <.demo_page
    id="toast-anatomy-page"
    title="Toast · Anatomy"
    subtitle="Create toasts via client bindings."
  >
    <.demo_section
      id="toast-anatomy-api"
      title="Client bindings"
      code={E2eWeb.Demos.ToastDemo.api_client_binding_code()}
    >
      <:preview><E2eWeb.Demos.ToastDemo.api_client_binding_example /></:preview>
    </.demo_section>
  </.demo_page>
</Layouts.app>
