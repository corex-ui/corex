<Layouts.app
  flash={@flash}
  mode={@mode}
  theme={@theme}
  locale={@locale}
  current_path={@current_path}
>
  <h1>
    New User
  </h1>
  <h2>Use this form to manage user records in your database.</h2>

  <.user_form
    changeset={@changeset}
    action={~p"/#{@locale}/users"}
    return_to={~p"/#{@locale}/users"}
  />
</Layouts.app>
