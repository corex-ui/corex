{<<"links">>,
 [{<<"GitHub">>,<<"https://github.com/elixir-makeup/makeup_eex">>}]}.
{<<"name">>,<<"makeup_eex">>}.
{<<"version">>,<<"2.0.2">>}.
{<<"description">>,<<"(H)EEx lexer for makeup">>}.
{<<"elixir">>,<<"~> 1.12">>}.
{<<"files">>,
 [<<"lib">>,<<"lib/makeup">>,<<"lib/makeup/lexers">>,
  <<"lib/makeup/lexers/eex_lexer">>,
  <<"lib/makeup/lexers/eex_lexer/splicer.ex">>,
  <<"lib/makeup/lexers/eex_lexer/testing.ex">>,
  <<"lib/makeup/lexers/eex_lexer/application.ex">>,
  <<"lib/makeup/lexers/heex_lexer.ex">>,<<"lib/makeup/lexers/eex_lexer.ex">>,
  <<".formatter.exs">>,<<"mix.exs">>,<<"README.md">>,<<"LICENSE">>]}.
{<<"app">>,<<"makeup_eex">>}.
{<<"licenses">>,[<<"BSD-2-Clause">>]}.
{<<"requirements">>,
 [[{<<"name">>,<<"makeup">>},
   {<<"app">>,<<"makeup">>},
   {<<"optional">>,false},
   {<<"requirement">>,<<"~> 1.2.1 or ~> 1.3">>},
   {<<"repository">>,<<"hexpm">>}],
  [{<<"name">>,<<"nimble_parsec">>},
   {<<"app">>,<<"nimble_parsec">>},
   {<<"optional">>,false},
   {<<"requirement">>,<<"~> 1.2">>},
   {<<"repository">>,<<"hexpm">>}],
  [{<<"name">>,<<"makeup_elixir">>},
   {<<"app">>,<<"makeup_elixir">>},
   {<<"optional">>,false},
   {<<"requirement">>,<<"~> 1.0">>},
   {<<"repository">>,<<"hexpm">>}],
  [{<<"name">>,<<"makeup_html">>},
   {<<"app">>,<<"makeup_html">>},
   {<<"optional">>,true},
   {<<"requirement">>,<<"~> 0.2.0 or ~> 1.0">>},
   {<<"repository">>,<<"hexpm">>}]]}.
{<<"build_tools">>,[<<"mix">>]}.
