{<<"app">>,<<"tds">>}.
{<<"build_tools">>,[<<"mix">>]}.
{<<"description">>,
 <<"Microsoft SQL Server client (Elixir implementation of the MS TDS protocol)">>}.
{<<"elixir">>,<<"~> 1.11">>}.
{<<"files">>,
 [<<"lib">>,<<"lib/tds">>,<<"lib/tds/types">>,<<"lib/tds/types/uuid.ex">>,
  <<"lib/tds/token_descriptors">>,<<"lib/tds/token_descriptors/basic.ex">>,
  <<"lib/tds/messages.ex">>,<<"lib/tds/versions.ex">>,<<"lib/tds/tls.ex">>,
  <<"lib/tds/encoding">>,<<"lib/tds/encoding/latin1.ex">>,
  <<"lib/tds/encoding/ucs2.ex">>,<<"lib/tds/parameter.ex">>,
  <<"lib/tds/protocol.ex">>,<<"lib/tds/types.ex">>,<<"lib/tds/errors.csv">>,
  <<"lib/tds/protocol">>,<<"lib/tds/protocol/col_metadata.ex">>,
  <<"lib/tds/protocol/grammar.ex">>,<<"lib/tds/protocol/collation.ex">>,
  <<"lib/tds/protocol/login7.ex">>,<<"lib/tds/protocol/header.ex">>,
  <<"lib/tds/protocol/token.ex">>,<<"lib/tds/protocol/prelogin.ex">>,
  <<"lib/tds/error.ex">>,<<"lib/tds/tokens.ex">>,
  <<"lib/tds/binary_utils.ex">>,<<"lib/tds/result.ex">>,
  <<"lib/tds/utils.ex">>,<<"lib/tds/query.ex">>,<<"lib/tds.ex">>,
  <<"mix.exs">>,<<"README.md">>,<<"CHANGELOG.md">>,<<"LICENSE">>]}.
{<<"licenses">>,[<<"Apache-2.0">>]}.
{<<"links">>,[{<<"Github">>,<<"https://github.com/elixir-ecto/tds">>}]}.
{<<"name">>,<<"tds">>}.
{<<"requirements">>,
 [[{<<"app">>,<<"decimal">>},
   {<<"name">>,<<"decimal">>},
   {<<"optional">>,false},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 1.9 or ~> 2.0">>}],
  [{<<"app">>,<<"jason">>},
   {<<"name">>,<<"jason">>},
   {<<"optional">>,true},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 1.0">>}],
  [{<<"app">>,<<"db_connection">>},
   {<<"name">>,<<"db_connection">>},
   {<<"optional">>,false},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 2.0">>}],
  [{<<"app">>,<<"table">>},
   {<<"name">>,<<"table">>},
   {<<"optional">>,true},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 0.1.0">>}]]}.
{<<"version">>,<<"2.3.5">>}.
