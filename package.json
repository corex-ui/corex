  "scripts": {
    "lint": "eslint assets",
    "lint:fix": "eslint assets --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"assets/**/*.{ts,js,json,css}\"",
    "format:check": "prettier --check \"assets/**/*.{ts,js,json,css}\"",
    "gen:components-dts": "node assets/scripts/gen-components-dts.mjs",
    "gen:components-dts:check": "node assets/scripts/gen-components-dts.mjs --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:js": "npm run typecheck && npm run format:check && npm run lint && npm run gen:components-dts:check",
    "check": "npm run test && npm run lint:js"
  },
  "devDependencies": {
